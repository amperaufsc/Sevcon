[4655sub6]
ParameterName=Status flags
ParameterValue=0x0000
ObjectType=7
DataType=6
AccessType=ro
LowLimit=0
HighLimit=0xFFFF
PDOMapping=1
DefaultValue=0
;SEVCONFIELD OBJECT_VERSION=1
;SEVCONFIELD ACCESS_LEVEL=4
;SEVCONFIELD DESCRIPTION=Status flags for H-protocol. For Gen4 size 8/10 all these bits should be set
;SEVCONFIELD DESCRIPTION=Bit0 0x0001 - DC link is charged
;SEVCONFIELD DESCRIPTION=Bit1 0x0002 - encoder initialised okay
;SEVCONFIELD DESCRIPTION=Bit2 0x0004 - current sensor autozeroed
;SEVCONFIELD DESCRIPTION=Bit3 0x0008 - pulsed enable input okay
;SEVCONFIELD DESCRIPTION=Bit4 0x0010 - lower IGBTs tested and okay
;SEVCONFIELD DESCRIPTION=Bit5 0x0020 - upper IGBTs tested and okay
;SEVCONFIELD DESCRIPTION=Bit6 0x0040 - motor parameters read okay
;SEVCONFIELD DESCRIPTION=Bit7 0x0080 - logic supply voltage okay
;SEVCONFIELD DESCRIPTION=Bit8 0x0100 - hardware variant recognised
;SEVCONFIELD DESCRIPTION=Bit9 0x0200 - digital/analogue inputs operating okay
;SEVCONFIELD DESCRIPTION=Bit10 0x0400 - no severe (or higher) faults set
;SEVCONFIELD DESCRIPTION=Bit11 0x0800 - H-protocol messages being received within Rx timeout and with valid checksum (configured in sub-index 2 and 3)
;SEVCONFIELD DESCRIPTION=For HVLP / Dragon8 / Gen5 the following bits are used:
;SEVCONFIELD DESCRIPTION=Bit10 0x0400 - no severe (or higher) faults set
;SEVCONFIELD DESCRIPTION=Bit11 0x0800 - H-protocol messages being received within Rx timeout and with valid checksum (configured in sub-index 2 and 3)
;SEVCONFIELD DESCRIPTION=Bit12 0x1000 - HVIL closed (if supported)
;SEVCONFIELD NUMBER_FORMAT=BASE16

