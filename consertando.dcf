[4000]
SubNumber=2
ObjectType=9
ParameterName=Logging Control
;SEVCONFIELD DESCRIPTION=Used to control all the logs. At present there is only one control item, the global reset.
;SEVCONFIELD OBJECT=ALL_LOGS_CTRL
;SEVCONFIELD CATEGORY=LOGGING

[4000sub0]
ParameterName=Number of entries
ParameterValue=0x01
ObjectType=7
DataType=5
AccessType=ro
LowLimit=0
HighLimit=0xFF
PDOMapping=0
DefaultValue=1
;SEVCONFIELD OBJECT_VERSION=1

[4000sub1]
ParameterName=Reset (write to reset all logs)
ParameterValue=0x00
ObjectType=7
DataType=1
AccessType=rw
LowLimit=0
HighLimit=1
PDOMapping=0
ObjFlags=0x1
DefaultValue=0
;SEVCONFIELD OBJECT_VERSION=1
;SEVCONFIELD ACCESS_LEVEL=5
;SEVCONFIELD DESCRIPTION=Writing to this index will reset all the logs. This reset can be performed differently to the individual log reset items in that it also initializes the EEPROM for log usage. This will need to be done after new software has been programmed into the controller. Read back a zero indicates log has been reset
;SEVCONFIELD NUMBER_FORMAT=2
;SEVCONFIELD 0=Reset
;SEVCONFIELD 1=Reset
;SEVCONFIELD COMMS_TIMEOUT=20000

[4100]
SubNumber=3
ObjectType=9
ParameterName=System FIFO Control
;SEVCONFIELD DESCRIPTION=Used to monitor and configure the System FIFO
;SEVCONFIELD OBJECT=SYSTEM_FIFO_CTRL
;SEVCONFIELD CATEGORY=LOGGING

[4100sub0]
ParameterName=Number of entries
ParameterValue=0x02
ObjectType=7
DataType=5
AccessType=ro
LowLimit=0
HighLimit=0xFF
PDOMapping=0
DefaultValue=3
;SEVCONFIELD OBJECT_VERSION=1

[4100sub1]
ParameterName=Reset (write to reset system FIFO)
ObjectType=7
DataType=1
AccessType=wo
LowLimit=0
HighLimit=1
PDOMapping=0
ObjFlags=0x1
DefaultValue=0
;SEVCONFIELD OBJECT_VERSION=1
;SEVCONFIELD ACCESS_LEVEL=2
;SEVCONFIELD DESCRIPTION=Writing to this index will reset the System FIFO. Only items with a log level less than of equal to the current logged in user access level will be deleted.
;SEVCONFIELD NUMBER_FORMAT=2
;SEVCONFIELD 0=Reset
;SEVCONFIELD 1=Reset
;SEVCONFIELD COMMS_TIMEOUT=20000

[4100sub2]
ParameterName=Number of items in System FIFO
