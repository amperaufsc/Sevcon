ParameterValue=0x00000000
ObjectType=7
DataType=7
AccessType=const
LowLimit=0
HighLimit=0xFFFFFFFF
PDOMapping=0
DefaultValue=0xFFFF0192
;SEVCONFIELD OBJECT_VERSION=1
;SEVCONFIELD DESCRIPTION=Contains information about the device type. This actually describes profiles. One node can have more than one profile (e.g. 1 or 2 Drives and Motion Control profiles and an I/O Module profile). The device type at this location is for the first profile. The device type for each profile is stored at 67FFh + (x * 800h), where x is the profile number. The value indicates it is a multiple profile device (FFFF) and the 1st profile is drives and motion (402d = 192h).
;SEVCONFIELD OBJECT=DEVICE_TYPE
;SEVCONFIELD CATEGORY=MONITORING
;SEVCONFIELD NUMBER_FORMAT=BIT_SPLIT
;SEVCONFIELD NUMBER_SPLIT=2
;SEVCONFIELD SPLIT=0
