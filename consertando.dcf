[1800sub2]
ParameterName=Transmission type
ParameterValue=0x01
ObjectType=7
DataType=5
AccessType=rw
LowLimit=0
HighLimit=0xFF
PDOMapping=0
DefaultValue=1
;SEVCONFIELD OBJECT_VERSION=1
;SEVCONFIELD ACCESS_LEVEL=4
;SEVCONFIELD DESCRIPTION=0x00 = Acyclic synchronous (SYNC), 0x01 to 0xF0 = Cyclic synchronous (SYNC)
;SEVCONFIELD DESCRIPTION=0xFE or 0xFF = Asynchronous (event driven)
;SEVCONFIELD WRITE_IN_PREOPERATIONAL_ONLY=TRUE
;SEVCONFIELD NUMBER_FORMAT=12
;SEVCONFIELD 0=Acyclic Synchronous
;SEVCONFIELD 1=1 SYNC to Tx
;SEVCONFIELD 2=2 SYNC to Tx
