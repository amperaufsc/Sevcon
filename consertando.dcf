;SEVCONFIELD BITSHIFT=0x8
;SEVCONFIELD LOW_LIMIT=0
;SEVCONFIELD HIGH_LIMIT=1
;SEVCONFIELD NUMBERFORMAT=2
;SEVCONFIELD 1=ToggleHi
