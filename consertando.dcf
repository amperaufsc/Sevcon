ObjectType=7
DataType=6
AccessType=ro
LowLimit=0
HighLimit=0xFFFF
PDOMapping=0
;SEVCONFIELD OBJECT_VERSION=1
;SEVCONFIELD DESCRIPTION=The current length of the System FIFO

