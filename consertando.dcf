DataType=5
AccessType=rw
LowLimit=0x00
HighLimit=0xFF
PDOMapping=0
DefaultValue=0x00
;SEVCONFIELD OBJECT_VERSION=1
;SEVCONFIELD ACCESS_LEVEL=4
