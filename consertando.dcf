;SEVCONFIELD HIGH_LIMIT=0xFFFF
;SEVCONFIELD NUMBERFORMAT=2
;SEVCONFIELD 402=Electric Drive
;SEVCONFIELD 401=Generic I/O
;SEVCONFIELD 419=Battery charger
;SEVCONFIELD 418=Battery module
;SEVCONFIELD 410 = inclinometer
;SEVCONFIELD SPLIT=1
